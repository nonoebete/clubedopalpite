# ═══════════════════════════════════════════════════════════════
#  .env — Clube de Palpites · Copa 2026
#  Copie para .env e preencha os valores reais
# ═══════════════════════════════════════════════════════════════

# ── Banco de dados ─────────────────────────────────────────────
POSTGRES_DB=clube_palpite
POSTGRES_USER=cdp_user
POSTGRES_PASSWORD=TROQUE_POR_SENHA_FORTE

# ── JWT ────────────────────────────────────────────────────────
# Gere com: openssl rand -hex 64
JWT_SECRET=TROQUE_POR_STRING_64_CHARS
JWT_EXPIRES_IN=8h

# ── App ────────────────────────────────────────────────────────
PORT=3333
NODE_ENV=production
APP_URL=https://seudominio.com.br

# ── Mercado Pago PIX ───────────────────────────────────────────
# https://www.mercadopago.com.br/developers/panel
# Token de produção começa com APP_USR-...
# Token de sandbox começa com TEST-... (para testes)
MP_ACCESS_TOKEN=APP_USR-COLE_SEU_TOKEN_AQUI
MP_WEBHOOK_SECRET=TROQUE_POR_SEGREDO_WEBHOOK

# ── WhatsApp Evolution API ─────────────────────────────────────
# Gere com: openssl rand -hex 32
EVOLUTION_API_KEY=TROQUE_POR_CHAVE_FORTE
# EVOLUTION_INSTANCE e EVOLUTION_API_URL já definidos no docker-compose
