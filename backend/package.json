{
  "name": "clube-palpite-api",
  "version": "1.0.0",
  "description": "API Completa — Clube de Palpites Copa do Mundo 2026",
  "main": "src/server.js",
  "scripts": {
    "dev":       "nodemon src/server.js",
    "start":     "node src/server.js",
    "db:push":   "prisma db push",
    "db:seed":   "node prisma/seed.js",
    "db:studio": "prisma studio",
    "db:reset":  "prisma db push --force-reset && node prisma/seed.js"
  },
  "dependencies": {
    "@prisma/client": "^5.0.0",
    "bcryptjs":       "^2.4.3",
    "cors":           "^2.8.5",
    "dotenv":         "^16.0.0",
    "express":        "^4.18.0",
    "jsonwebtoken":   "^9.0.0"
  },
  "devDependencies": {
    "nodemon": "^3.0.0",
    "prisma":  "^5.0.0"
  }
}
